# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot (desde @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=

# IDs de usuarios permitidos (separados por comas). Obtén tu ID con @userinfobot
TELEGRAM_ALLOWED_USERS=

# Canal por defecto para cron y notificaciones (opcional)
TELEGRAM_HOME_CHANNEL=

# ── Modelo LLM ────────────────────────────────────────────────────────────────
# MiniMax (por defecto)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# ── NimElectric API ───────────────────────────────────────────────────────────
NIMELECTRIC_API_KEY=
NIMELECTRIC_BASE_URL=https://api.nimelectric.com
